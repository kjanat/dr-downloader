{
	"$schema": "node_modules/@biomejs/biome/configuration_schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true,
		"defaultBranch": "master"
	},
	"files": { "ignoreUnknown": true },
	"formatter": { "enabled": false },
	"linter": {
		"enabled": true,
		"rules": {
			"complexity": {
				"noExcessiveCognitiveComplexity": "error"
			}
		},
		"domains": {
			"project": "recommended",
			"test": "recommended"
		}
	},
	"json": {
		"parser": { "allowTrailingCommas": false },
		"formatter": { "trailingCommas": "none" },
		"linter": { "enabled": false }
	},
	"assist": {
		"actions": {
			"recommended": true,
			"source": {
				"organizeImports": "off"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/*.test.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		},
		{
			"includes": ["**/*.jsonc", ".vscode/*.json", ".zed/*.json"],
			"json": {
				"parser": {
					"allowComments": true,
					"allowTrailingCommas": true
				},
				"linter": { "enabled": false }
			}
		}
	]
}
