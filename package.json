{
  "name": "dr-downloader",
  "module": "src/main.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "bun --watch src/main.ts",
    "fake": "bun run src/main.ts --test",
    "postinstall": "puppeteer browsers install chrome",
    "format": "biome format --write",
    "lint": "biome lint",
    "lint:fix": "biome check --write",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "puppeteer": "^24.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.5",
    "@types/bun": "^1.3.0",
    "@types/node": "^24.7.2",
    "@typescript/native-preview": "^7.0.0-dev.20251012.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
