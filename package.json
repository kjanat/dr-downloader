{
  "name": "dr-downloader",
  "module": "daVinciDownloader.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run daVinciDownloader.ts",
    "dev": "bun --watch daVinciDownloader.ts",
    "fake": "bun run daVinciDownloader.ts --test",
    "postinstall": "puppeteer browsers install chrome",
