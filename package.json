{
	"name": "davinci-resolve-downloader",
	"version": "1.0.0-alpha.1",
	"description": "Download the free edition of DaVinci Resolve from Blackmagic Design",
	"repository": "kjanat/dr-downloader",
	"license": "MIT",
	"type": "module",
	"module": "src/main.ts",
	"keywords": ["davinci resolve", "download", "dreamcli"],
	"bin": {
		"dr-downloader": "dist/main.js"
	},
	"imports": {
		"#*": "./src/*.ts",
		"#pkg": "./package.json"
	},
	"scripts": {
		"build": "bun build src/main.ts --format esm --target node --outdir dist --minify",
		"fake": "bun run src/main.ts --test",
		"format": "dprint fmt",
		"postinstall": "puppeteer browsers install chrome",
		"lint": "biome lint",
		"lint:fix": "biome lint --write",
		"prepublish": "bun run build",
		"start": "bun run src/main.ts",
		"typecheck": "tsgo --noEmit",
		"dr-downloader": "run start"
	},
	"dependencies": {
		"@kjanat/dreamcli": "^2.3",
		"puppeteer": "^25"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5",
		"@types/bun": "^1.3",
		"@types/node": "^26",
		"@typescript/native-preview": "^7.0.0-dev"
	},
	"peerDependencies": {
		"typescript": "^6"
	},
	"packageManager": "bun@1.3.14"
}
