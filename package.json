{
	"name": "davinci-resolve-downloader",
	"version": "1.0.0-alpha.2",
	"description": "Download the free edition of DaVinci Resolve from Blackmagic Design",
	"keywords": ["davinci resolve", "download", "dreamcli"],
	"bugs": { "url": "https://github.com/kjanat/dr-downloader/issues" },
	"repository": { "type": "git", "url": "git+https://github.com/kjanat/dr-downloader.git" },
	"license": "MIT",
	"author": "Kaj Kowalski",
	"type": "module",
	"imports": { "#*": "./src/*.ts", "#pkg": "./package.json" },
	"module": "src/main.ts",
	"bin": { "dr-downloader": "dist/main.js" },
	"files": ["dist/main.js"],
	"scripts": {
		"build": "bun build src/main.ts --format esm --target node --outdir dist --minify",
		"dr-downloader": "run start",
		"fake": "bun src/main.ts --test",
		"format": "dprint fmt",
		"postinstall": "puppeteer browsers install chrome",
		"lint": "biome lint",
		"lint:fix": "biome lint --write",
		"prepack": "run build",
		"start": "bun src/main.ts",
		"typecheck": "tsgo --noEmit"
	},
	"dependencies": {
		"@kjanat/dreamcli": "^2.3",
		"puppeteer": "^25"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5",
		"@types/bun": "^1.3",
		"@types/node": "^26",
		"@typescript/native-preview": "^7.0.0-dev",
		"runner-run": "^0.13.1"
	},
	"peerDependencies": { "typescript": "^6" },
	"packageManager": "bun@1.3.14",
	"volta": { "node": "26.3.1", "npm": "11.17.0" }
}
