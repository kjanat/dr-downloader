{
	"name": "davinci-resolve-downloader",
	"version": "1.0.0-alpha.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/dr-downloader.git"
	},
	"license": "MIT",
	"type": "module",
	"module": "src/main.ts",
	"bin": {
		"dr-downloader": "dist/main.js"
	},
	"scripts": {
		"build": "bun build src/main.ts --format esm --target node --outdir dist --minify",
		"fake": "bun run src/main.ts --test",
		"format": "dprint fmt .",
		"postinstall": "puppeteer browsers install chrome",
		"lint": "biome lint",
		"lint:fix": "biome lint --write",
		"prepublish": "bun run build",
		"start": "bun run src/main.ts",
		"typecheck": "tsgo --noEmit"
	},
	"dependencies": {
		"puppeteer": "^24"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4",
		"@types/bun": "^1.3",
		"@types/node": "^24",
		"@typescript/native-preview": "^7.0.0-dev.20260219.1"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"packageManager": "bun@1.3.9"
}
