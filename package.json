{
	"name": "davinci-resolve-downloader",
	"version": "1.0.1",
	"description": "Download the free edition of DaVinci Resolve from Blackmagic Design",
	"keywords": ["davinci resolve", "download", "dreamcli"],
	"bugs": {
		"url": "https://github.com/kjanat/dr-downloader/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/dr-downloader.git"
	},
	"license": "MIT",
	"author": "Kaj Kowalski",
	"type": "module",
	"imports": {
		"#*": "./src/*.ts",
		"#pkg": "./package.json"
	},
	"module": "src/main.ts",
	"bin": {
		"dr-downloader": "dist/main.js"
	},
	"files": ["dist/main.js"],
	"scripts": {
		"build": "bun build src/main.ts --format esm --target node --outdir dist --minify",
		"dr-downloader": "run start",
		"fake": "bun src/main.ts --test",
		"format": "dprint fmt",
		"lint": "biome lint",
		"lint:fix": "biome lint --write",
		"prepack": "run build",
		"start": "bun src/main.ts",
		"typecheck": "tsgo --noEmit"
	},
	"dependencies": {
		"@kjanat/dreamcli": "^2.4.0",
		"puppeteer": "^25.2.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@types/bun": "^1.3.14",
		"@types/node": "^26.0.0",
		"@typescript/native-preview": "^7.0.0-dev.20260623.1",
		"runner-run": "^0.14.0"
	},
	"peerDependencies": {
		"typescript": "^6.0.3"
	},
	"packageManager": "bun@1.3.14",
	"volta": {
		"node": "26.3.1",
		"npm": "11.17.0"
	}
}
