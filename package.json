		"start": "bun run src/main.ts",
		"typecheck": "tsgo --noEmit"
	},
	"dependencies": {
		"puppeteer": "^24"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4",
		"@types/bun": "^1.3",
		"@types/node": "^24",
		"@typescript/native-preview": "^7.0.0-dev.20260219.1"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"packageManager": "bun@1.3.9"
}
