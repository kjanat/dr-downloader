    "lint:fix": "biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@types/bun": "^1.2.22",
    "@types/node": "^24.4.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "puppeteer": "^24.20.0"
  }
}
