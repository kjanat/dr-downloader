				"tw",
				"ua",
				"uk",
				"us"
			]
		},
		"retryAttempts": {
			"description": "Download retry attempts. Default 3.",
			"type": "integer",
			"minimum": 0
		},
		"state": {
			"description": "State/province. Required for US/CA.",
			"type": "string"
		},
		"street": {
			"description": "Street address.",
			"type": "string",
			"minLength": 1
		},
		"timeout": {
			"description": "Download timeout in milliseconds. Default 900000 (15 min).",
			"type": "integer",
			"minimum": 1
		},
		"zipcode": {
			"description": "Postal/zip code. Letters, digits, spaces and dashes.",
			"type": "string",
			"pattern": "^[A-Za-z0-9\\s-]+$"
		}
	},
	"additionalProperties": false
