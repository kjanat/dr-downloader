		"email": {
			"$comment": "BMD bmdEmailValidator regex; keep in sync with ValidationService.EMAIL_PATTERN.",
			"description": "Email address. Use a real one to register as yourself; the default is an obvious placeholder.",
			"type": "string",
			"pattern": "^(([^<>()[\\].,;:\\s@\"]+(\\.[^<>()[\\].,;:\\s@\"]+)*)|.(\".+\"))@((\\[[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}])|(([A-Za-z0-9-]+\\.)+[A-Za-z0-9-]{2,}))$",
			"format": "email"
		},
		"firstname": {
			"description": "First name.",
			"type": "string",
			"minLength": 1
		},
		"lastname": {
			"description": "Last name.",
			"type": "string",
			"minLength": 1
		},
		"output": {
			"description": "Download directory. Defaults to ~/Downloads.",
			"type": "string",
			"minLength": 1
		},
		"phone": {
			"$comment": "BMD bmdPhoneValidator regex; keep in sync with ValidationService.PHONE_PATTERN.",
			"description": "Phone number. Digits, spaces, parentheses, plus and minus only.",
			"type": "string",
			"pattern": "^[\\s\\d()+-]+$"
		},
		"platform": {
			"description": "Target platform. Defaults to autodetect.",
			"type": "string",
			"enum": [
				"linux",
				"mac",
				"windows",
				"winarm"
			]
		},
		"region": {
			"description": "BMD support region for the /api/support/<region>/ endpoint, a 2-letter code (lowercase). Blackmagic Design's operating territories; \"gb\" is accepted as an alias for \"uk\".",
			"type": "string",
			"enum": [
				"ae",
				"ar",
				"at",
				"au",
				"br",
				"ca",
